# 다스코(dasco)와 동일한 부모(DreamIT Biz) 인프라를 공유합니다.
# → 아래 Supabase/OAuth 값은 dasco에서 쓰는 값과 동일하게 입력하세요.
# (Supabase 미설정 시 토큰 배당/키는 localStorage로 동작 — 단일 브라우저 데모)

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PortOne (카드결제) — 현재 사이트는 미사용(features.shop=false)이나 호환 위해 유지
VITE_PORTONE_STORE_ID=your-store-id
VITE_PORTONE_CHANNEL_KEY=your-channel-key

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Kakao OAuth
VITE_KAKAO_CLIENT_ID=your-kakao-client-id

# Site URL (배포 도메인) — 이 값만 ai-free 도메인으로 변경
VITE_SITE_URL=https://ai-free.dreamitbiz.com

# 참고: AI 제공자 API 키(OpenAI/Anthropic/Gemini)는 .env가 아니라
# 사이트 내 "토큰 배당 관리"(강사 전용) 화면에서 충전합니다.
