# Supabase (선택) — 설정 시 토큰 배당/API 키가 Supabase에 저장되어 여러 기기에서 공유됩니다.
# 미설정 시 localStorage로 동작합니다(단일 브라우저 데모).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Kakao OAuth
VITE_KAKAO_CLIENT_ID=your-kakao-client-id

# Site URL (배포 도메인)
VITE_SITE_URL=https://ai-free.dreamitbiz.com

# 참고: AI 제공자 API 키(OpenAI/Anthropic/Gemini)는 .env가 아니라
# 사이트 내 "토큰 배당 관리"(강사 전용) 화면에서 충전합니다.
